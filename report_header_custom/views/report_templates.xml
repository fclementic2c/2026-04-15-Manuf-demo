<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_standard_inherit" inherit_id="web.external_layout_standard">
        <!-- Target company logo image -->
        <xpath expr="//img[@t-if='company.logo']" position="attributes">
            <attribute name="style">width: 300px !important; max-height: none !important; float: left !important; display: block !important;</attribute>
        </xpath>
        
        <!-- Ensure company address is right-aligned to make room for large logo -->
        <xpath expr="//div[@name='company_address']" position="attributes">
            <attribute name="style">text-align: right !important;</attribute>
        </xpath>
    </template>
</odoo>
