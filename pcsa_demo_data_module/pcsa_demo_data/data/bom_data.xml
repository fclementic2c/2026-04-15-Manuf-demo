    <record id="bom_bras" model="mrp.bom">
        <field name="product_tmpl_id" ref="product_bras_robotique_v1"/>
        <field name="product_qty">1.0</field>
        <field name="type">normal</field>
        <field name="bom_line_ids" eval="[(0, 0, {
            'product_id': ref('product_vis_m8'),
            'product_qty': 4.0,
        })]"/>
    </record>

    <!-- BOM Niveau 1 (Châssis) -->
    <record id="bom_chassis" model="mrp.bom">
        <field name="product_tmpl_id" ref="product_chassis_v1"/>
        <field name="product_qty">1.0</field>
        <field name="type">normal</field>
        <field name="bom_line_ids" eval="[(0, 0, {
            'product_id': ref('product_bras_robotique_v1'),
            'product_qty': 1.0,
        })]"/>
    </record>

    <!-- BOM Niveau 0 (Machine Finale) -->
    <record id="bom_machine_finale" model="mrp.bom">
        <field name="product_tmpl_id" ref="product_machine_pharma_v1"/>
        <field name="product_qty">1.0</field>
        <field name="type">normal</field>
        <field name="bom_line_ids" eval="[
            (0, 0, {
                'product_id': ref('product_chassis_v1'),
                'product_qty': 1.0,
            }),
            (0, 0, {
                'product_id': ref('product_moteur_servo'),
                'product_qty': 2.0,
            })
        ]"/>
