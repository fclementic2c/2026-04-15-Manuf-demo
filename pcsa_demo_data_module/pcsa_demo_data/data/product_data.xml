<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Catégorie avec FIFO/Automated -->
    <record id="product_category_pcsa" model="product.category">
        <field name="name">Machines PCSA (FIFO)</field>
        <field name="parent_id" ref="product.product_category_all"/>
        <field name="property_cost_method">fifo</field>
        <field name="property_valuation">real_time</field>
    </record>

    <!-- Machine Finale (Niveau 0) -->
    <record id="product_machine_pharma_v1" model="product.product">
        <field name="name">Machine de Conditionnement Pharma - V1</field>
        <field name="default_code">EC123-098-1000-V01</field>
        <field name="type">product</field>
        <field name="categ_id" ref="product_category_pcsa"/>
    </record>

    <!-- Sous-ensemble Châssis (Niveau 1) -->
    <record id="product_chassis_v1" model="product.product">
        <field name="name">Sous-ensemble Châssis Inox - V1</field>
        <field name="default_code">EC123-098-2100-V01</field>
        <field name="type">product</field>
        <field name="categ_id" ref="product_category_pcsa"/>
    </record>

    <!-- Composant fabriqué (Niveau 2) -->
    <record id="product_bras_robotique_v1" model="product.product">
        <field name="name">Bras de préhension Inox - V1</field>
        <field name="default_code">EC123-098-3210-V01</field>
        <field name="type">product</field>
        <field name="categ_id" ref="product_category_pcsa"/>
    </record>

    <!-- Article Acheté PCSA (AC) -->
    <record id="product_moteur_servo" model="product.product">
        <field name="name">Moteur Servo 400W</field>
        <field name="default_code">AC0042</field>
        <field name="type">product</field>
        <field name="purchase_ok" eval="True"/>
    </record>

    <!-- Article Catalogue (DIN) -->
    <record id="product_vis_m8" model="product.product">
        <field name="name">Vis CHC M8x40 Inox A4</field>
        <field name="default_code">DIN912.08.040.316L</field>
        <field name="type">product</field>
    </record>
</odoo>
