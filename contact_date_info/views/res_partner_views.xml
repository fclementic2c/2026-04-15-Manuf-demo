<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_contact_date" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.contact.date</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="contact_date" placeholder="Date de contact"/>
            </xpath>
        </field>
    </record>
</odoo>
